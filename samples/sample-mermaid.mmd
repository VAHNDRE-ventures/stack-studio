flowchart TD
  subgraph CLIENTS["1 · Clients"]
    WEB["Web App<br/>React SPA"]
    MOBILE["Mobile App<br/>iOS / Android"]
  end

  subgraph EDGE["2 · Edge"]
    CDN["CDN / Cache"]
    GW{API Gateway}
  end
  CLIENTS --> CDN

  subgraph SVC["3 · Services"]
    AUTH(Auth Service)
    ORDERS(Orders Service)
    BILLING(Billing Service)
  end
  CDN --> GW
  GW -- "JWT" --> AUTH
  GW --> ORDERS & BILLING

  subgraph DATA["4 · Data"]
    PG[(Postgres)]
    REDIS[(Redis)]
  end
  ORDERS --> PG
  AUTH --> REDIS
  BILLING -. "async settle" .-> PG

  USER((Customer))
  USER --> WEB
